{
  "compilerOptions": {
    "rootDir": "lib/",
    "outDir": "./dist",
    "target": "es2017",
    "module": "commonjs",
    "declaration": true,
    "esModuleInterop": true,
    "types": ["node"],

    "noImplicitAny": false,
    "noImplicitThis": false,
    "strictPropertyInitialization": false,
    "noImplicitReturns": true,
  },
  "include": [
    "./lib/**/*"
  ]
}
