{
  "compilerOptions": {
    "rootDir": "lib/",
    "outDir": "build/cjs/",
    "target": "es2018", // Node.js 10 (https://github.com/microsoft/TypeScript/wiki/Node-Target-Mapping)
    "module": "commonjs",
    "declaration": true,
    "esModuleInterop": true,
    "strict": false,
    "types": ["node", "mocha"],
  },
  "include": [
    "./lib/**/*"
  ]
}
